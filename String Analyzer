CODE:

text = "   Python Programming Language 2025   "

print("Original Text:'", text, "'", sep="")
clean = text.strip()

print("After strip:'", clean, "'", sep="")
print("Length:", len(clean))
print("Uppercase:", clean.upper())
print("Lowercase:", clean.lower())
print("Title Case:", clean.title())

print("Vowels count:", sum(1 for ch in clean.lower() if ch in "aeiou"))
print("Digits count:", sum(1 for ch in clean if ch.isdigit()))
print("Spaces count:", clean.count(" "))


